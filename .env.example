# Copy to .env (setup.sh does this automatically).
# These are LOCAL, NON-SECRET development defaults — the whole stack runs on
# localhost and nothing here is a real credential.

# --- PostgreSQL / pgvector (runs in Docker) ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=ragdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Ollama (runs natively on the host) ---
OLLAMA_HOST=http://localhost:11434
GEN_MODEL=gemma2:2b
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# --- Retrieval settings ---
TOP_K=4
